// Copy to esp32_lab_camera/secrets.h (same folder as esp32_lab_camera.ino).
// secrets.h is gitignored — never commit real credentials.

#pragma once

// WiFi — set WIFI_USE_ENTERPRISE to 1 for uwosecure-v2 / eduroam (PEAP + MSCHAPv2)
#define WIFI_USE_ENTERPRISE 0

#define WIFI_SSID "your-wifi-name"

// WPA2 personal (home WiFi): SSID + password only
#define WIFI_PASSWORD "your-wifi-password"

// WPA2 enterprise (uwosecure-v2): Western user ID + password (same as phone/tablet login)
#define EAP_IDENTITY "your-western-username"
#define EAP_USERNAME "your-western-username"
#define EAP_PASSWORD "your-western-password"

// Secret token required to open /stream (use a long random string)
#define STREAM_TOKEN "change-me-to-a-long-random-string"
